source configs/hardware/a100_8x40g_pcie.env

export RUN_NAME=qwen3_8b_grpo_v14_compact_exec_n4
export MODEL_NAME=${RL_DATA_ROOT}/models/qwen3-8b
export TRAIN_DATA=${DATA_ROOT}/critpt_v14_compact_exec_train.parquet
export VAL_DATA=${DATA_ROOT}/critpt_v14_compact_exec_val.parquet
export ROLLOUT_DATA_DIR=${RL_DATA_ROOT}/rollouts/${RUN_NAME}
export REWARD_PATH=$(pwd)/src/rl_posttrain/critpt_synth/verl_reward_v14_compact.py

# V14 trains against the failure modes found on official public test:
# syntax/execution, compact code, anti-runaway repetition, and sparse/large returns.
export MAX_PROMPT_LENGTH=4096
export MAX_RESPONSE_LENGTH=2048
export ROLLOUT_MAX_MODEL_LEN=6144
export TRAIN_BATCH_SIZE=4
export PPO_MINI_BATCH_SIZE=4
export MICRO_BATCH_SIZE_PER_GPU=1
export ROLLOUT_N=4
export ROLLOUT_TP_SIZE=2
export ROLLOUT_MAX_NUM_SEQS=16
export ROLLOUT_MAX_NUM_BATCHED_TOKENS=12288
export VLLM_GPU_MEMORY_UTILIZATION=0.34
export N_GPUS_PER_NODE=8
export NNODES=1

export TOTAL_TRAINING_STEPS=80
export SAVE_FREQ=40
export TEST_FREQ=0
export VAL_BEFORE_TRAIN=false
export TOTAL_EPOCHS=1
