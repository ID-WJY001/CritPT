source configs/hardware/a100_8x40g_pcie.env

export RUN_NAME=qwen3_8b_grpo_v20_focused_hard_from_v19_gs60_n8
export MODEL_NAME=${RL_DATA_ROOT}/models/qwen3-8b-v19-failure-mined-n8-gs60
export TRAIN_DATA=${DATA_ROOT}/critpt_v20_focused_hard_train.parquet
export VAL_DATA=${DATA_ROOT}/critpt_v20_focused_hard_val.parquet
export ROLLOUT_DATA_DIR=${RL_DATA_ROOT}/rollouts/${RUN_NAME}
export REWARD_PATH=$(pwd)/src/rl_posttrain/critpt_synth/verl_reward_v20_focused_hard.py

# V20 is the follow-up if V19 step60 still fails official/visual checks.
# It focuses on the three visible V19 rollout problems: canonical tr(...) labels,
# empty interval survivor sets, and HHG/OAM runtime-safe local variables.
export ADV_ESTIMATOR=grpo
export ENABLE_THINKING=false
export ROLLOUT_TEMPERATURE=1.50
export ROLLOUT_TOP_P=1.0
export ROLLOUT_TOP_K=-1
export ROLLOUT_N=8
export TRAIN_BATCH_SIZE=2
export PPO_MINI_BATCH_SIZE=2
export MICRO_BATCH_SIZE_PER_GPU=1

export MAX_PROMPT_LENGTH=6144
export MAX_RESPONSE_LENGTH=2048
export ROLLOUT_MAX_MODEL_LEN=8192
export ROLLOUT_TP_SIZE=4
export ROLLOUT_MAX_NUM_SEQS=16
export ROLLOUT_MAX_NUM_BATCHED_TOKENS=12288
export VLLM_GPU_MEMORY_UTILIZATION=0.34
export N_GPUS_PER_NODE=8
export NNODES=1

export TOTAL_TRAINING_STEPS=80
export SAVE_FREQ=40
export TEST_FREQ=0
export VAL_BEFORE_TRAIN=false
export TOTAL_EPOCHS=1
