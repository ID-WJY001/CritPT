source configs/hardware/a100_8x40g_pcie.env

export RUN_NAME=qwen3_8b_grpo_v13_official_code_format_signal_n4
export MODEL_NAME=${RL_DATA_ROOT}/models/qwen3-8b
export TRAIN_DATA=${DATA_ROOT}/critpt_v13_official_style_train.parquet
export VAL_DATA=${DATA_ROOT}/critpt_v13_official_style_val.parquet
export ROLLOUT_DATA_DIR=${RL_DATA_ROOT}/rollouts/${RUN_NAME}
export REWARD_PATH=$(pwd)/src/rl_posttrain/critpt_synth/verl_reward.py

# Same total rollout count as batch=8,n=2, but four samples per prompt so GRPO
# has a better chance of seeing within-prompt reward variance.
export MAX_PROMPT_LENGTH=2048
export MAX_RESPONSE_LENGTH=1536
export ROLLOUT_MAX_MODEL_LEN=4096
export TRAIN_BATCH_SIZE=4
export PPO_MINI_BATCH_SIZE=4
export MICRO_BATCH_SIZE_PER_GPU=1
export ROLLOUT_N=4
export ROLLOUT_TP_SIZE=2
export ROLLOUT_MAX_NUM_SEQS=16
export ROLLOUT_MAX_NUM_BATCHED_TOKENS=8192
export VLLM_GPU_MEMORY_UTILIZATION=0.30
export N_GPUS_PER_NODE=8
export NNODES=1

export TOTAL_TRAINING_STEPS=50
export SAVE_FREQ=50
export TEST_FREQ=0
export VAL_BEFORE_TRAIN=false
export TOTAL_EPOCHS=1
