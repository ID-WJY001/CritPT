# Copy this file to .env or another private env file before running LLM-judge
# jobs. Never commit real keys.

# OpenAI-compatible judge endpoint, for example a hosted gateway.
OPENAI_BASE_URL=https://example.com/v1
OPENAI_API_KEY=replace_me
OPENAI_MODEL=replace_me

# Optional official/evaluation API key.
AA_API_KEY=replace_me

# Optional remote training target.
GPU_HOST=replace_me
GPU_PORT=22
GPU_USER=root

